<UserControl x:Class="FoundationDetailsLibraryAutoCAD.UI.Controls.BeamControls.BeamDimensionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             MinHeight="34">

    <Border Background="#2D2D30" Padding="4" CornerRadius="3">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Width StackPanel -->
            <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">

                <!-- Input Label -->
                <TextBlock Text="W"
               FontSize="10"
               Foreground="#AAAAAA"
               HorizontalAlignment="Center"
               Margin="0,0,0,1">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Mode, ElementName=Root}" Value="Display">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Display Label -->
                <TextBlock x:Name="WidthText"
               FontSize="11"
               Foreground="White"
               HorizontalAlignment="Center"
               Visibility="Collapsed">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Mode, ElementName=Root}" Value="Display">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Combo -->
                <ComboBox x:Name="WidthCombo"
              Width="60"
              Height="22"
              FontSize="11"
              VerticalContentAlignment="Center"
              ToolTip="Width (inches)"
              SelectedItem="{Binding WidthValue, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Mode, ElementName=Root}" Value="Display">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>
            </StackPanel>

            <!-- Depth StackPanel -->
            <StackPanel Grid.Column="6" Orientation="Vertical" VerticalAlignment="Center">

                <!-- Input Label -->
                <TextBlock Text="D"
               FontSize="10"
               Foreground="#AAAAAA"
               HorizontalAlignment="Center"
               Margin="0,0,0,1">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Mode, ElementName=Root}" Value="Display">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Display Label -->
                <TextBlock x:Name="DepthText"
               FontSize="11"
               Foreground="White"
               HorizontalAlignment="Center"
               Visibility="Collapsed">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Mode, ElementName=Root}" Value="Display">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Combo -->
                <ComboBox x:Name="DepthCombo"
              Width="60"
              Height="22"
              FontSize="11"
              VerticalContentAlignment="Center"
              ToolTip="Depth (inches)"
              SelectedItem="{Binding DepthValue, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Mode, ElementName=Root}" Value="Display">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
