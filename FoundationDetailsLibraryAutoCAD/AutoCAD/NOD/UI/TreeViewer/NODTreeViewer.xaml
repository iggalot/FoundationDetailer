<UserControl x:Class="FoundationDetailsLibraryAutoCAD.AutoCAD.NOD.UI.TreeViewer.NODTreeViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FoundationDetailsLibraryAutoCAD.AutoCAD.NOD.UI.TreeViewer"
             Height="400" Width="350">

    <Grid>
        <TreeView x:Name="Tree"
          ItemsSource="{Binding}"
          SelectedItemChanged="Tree_SelectedItemChanged">
            

            <TreeView.Resources>

                <HierarchicalDataTemplate DataType="{x:Type local:NODTreeNode}"
                                  ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding Name}" />
                </HierarchicalDataTemplate>

            </TreeView.Resources>

        </TreeView>
    </Grid>
</UserControl>